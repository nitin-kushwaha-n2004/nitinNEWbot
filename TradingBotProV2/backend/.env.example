PORT=5000
MONGO_URI=mongodb://localhost:27017/tradingbot
JWT_SECRET=your_super_secret_jwt_key_here

# ─── TRADING PLATFORM (choose one) ──────────────────────────────────────────
# Delta Exchange (India) — Recommended
DELTA_API_KEY=your_delta_api_key
DELTA_SECRET_KEY=your_delta_secret_key
DELTA_BASE_URL=https://api.india.delta.exchange
DELTA_TESTNET=true

# Binance (optional — if using Binance instead)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret_key
BINANCE_TESTNET=true

# ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Twilio (WhatsApp/Call alerts — optional)
# TWILIO_ACCOUNT_SID=removed_for_github
# TWILIO_AUTH_TOKEN=removed_for_github
# TWILIO_PHONE=+1415xxxxxxx
# YOUR_PHONE=+91xxxxxxxxxx

# ─── TRADINGVIEW ─────────────────────────────────────────────────────────────
TRADINGVIEW_WEBHOOK_SECRET=your_webhook_secret
